void cal_sz(int node, int pr) {
  tot += 1;
  sz[node] = 1;
  for (auto &son : g[node]) {
    if (pr != son && !removed[son]) {
      cal_sz(son, node);
      sz[node] += sz[son];
    }
  }
}

int find_cen(int node, int pr) {
  for (auto &son : g[node]) {
    if (son == pr || removed[son]) continue;
    if (sz[son] > tot / 2) return find_cen(son, node);
  }
  return node;
}

void decompose(int node) {
  tot = 0;
  cal_sz(node, -1);
  int cen = find_cen(node, -1);
  removed[cen] = 1;


